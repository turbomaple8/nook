{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "nookrent.com"
        }
      ],
      "destination": "https://www.nookrent.com/:path*",
      "permanent": true
    },
    {
      "source": "/room-master-islington",
      "destination": "/rooms",
      "permanent": true
    },
    {
      "source": "/room-master-islington.html",
      "destination": "/rooms",
      "permanent": true
    },
    {
      "source": "/cookies",
      "destination": "/cookie-policy",
      "permanent": true
    },
    {
      "source": "/cookies.html",
      "destination": "/cookie-policy",
      "permanent": true
    }
  ]
}
